# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/bulletindb
SPRING_DATASOURCE_DRIVER_CLASS=org.postgresql.Driver
SPRING_DATASOURCE_USERNAME=user
SPRING_DATASOURCE_PASSWORD=password

# Hibernate Dialect
HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# H2 Console (disable in production)
H2_CONSOLE_ENABLED=false

# Server Configuration
SERVER_PORT=8000

# CORS Configuration
CORS_ALLOWED_ORIGINS=https://your-frontend-url.com,https://your-railway-preview-url.up.railway.app

# JWT Secret (REQUIRED in production - generate a secure random key)
JWT_SECRET=your-jwt-secret-key-at-least-256-bits-long

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
MAIL_FROM=noreply@bulletin.local

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Admin init key
ADMIN_INIT_KEY=BULLETIN_INIT_2024_SECURE_KEY_CHANGE_ME

# Upload directories
UPLOAD_DIR=/tmp/uploads
MAX_FILE_SIZE=150MB

# Logging Level
LOG_LEVEL=INFO
