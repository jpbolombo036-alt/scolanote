# Railway Environment Variables for Bulletin Gestion
# Copy relevant values to Railway dashboard (Settings → Variables)

# Database (Railway PostgreSQL)
SPRING_DATASOURCE_URL=jdbc:postgresql://<RAILWAY_POSTGRES_HOST>:5432/bulletindb
SPRING_DATASOURCE_DRIVER_CLASS=org.postgresql.Driver
SPRING_DATASOURCE_USERNAME=<RAILWAY_POSTGRES_USER>
SPRING_DATASOURCE_PASSWORD=<RAILWAY_POSTGRES_PASSWORD>

# JWT Secret (generate a secure random key, at least 256 bits)
JWT_SECRET=your-jwt-secret-key-at-least-256-bits-long

# Server
SERVER_PORT=8000

# CORS (include Railway URL and frontend URLs)
CORS_ALLOWED_ORIGINS=https://your-frontend-url.com,http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
MAIL_FROM=noreply@bulletin.local

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Admin init key
ADMIN_INIT_KEY=BULLETIN_INIT_2024_SECURE_KEY_CHANGE_ME

# Upload directories (use /tmp for Railway)
UPLOAD_DIR=/tmp/uploads
MAX_FILE_SIZE=150MB

# Logging Level
LOG_LEVEL=INFO
